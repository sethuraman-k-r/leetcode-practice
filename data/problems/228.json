ges.append(f\"{start}\")\n                else:\n                    ranges.append(f\"{start}->{end}\")\n                start = nums[i]\n                end = nums[i]\n        \n        # Add the last range\n        if start == end:\n            ranges.append(f\"{start}\")\n        else:\n            ranges.append(f\"{start}->{end}\")\n        \n        return ranges\n```", "estimated_date": 1438905600000}