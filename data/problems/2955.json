28],[0,28],[7,21]]", "output": "[15, 14, 14, 11, 169, 50]"}, {"input": "s = \"aaaaaaaabbbbbbbbcccccccc\", queries = [[0,7],[8,15],[16,23],[0,15],[8,23],[0,23]]", "output": "[36, 36, 36, 72, 72, 108]"}, {"input": "s = \"aaaaabbbbbcccccddddd\", queries = [[0,4],[5,9],[10,14],[15,19],[0,9],[5,14],[10,19],[0,14],[5,19],[0,19]]", "output": "[15, 15, 15, 15, 30, 30, 30, 45, 45, 60]"}, {"input": "s = \"abcabcabcabcabcabcabcabcabc\", queries = [[0,26],[1,25],[2,24],[3,23],[4,22],[5,21],[6,20],[7,19],[8,18],[9,17],[10,16],[11,15],[12,14],[13,13]]", "output": "[135, 117, 100, 84, 70, 57, 45, 35, 26, 18, 12, 7, 3, 1]"}, {"input": "s = \"abcabcabcabcabcabcabcabcabcabcabcabc\", queries = [[0,5],[5,10],[10,15],[15,20],[20,25],[25,30],[30,35],[0,35]]", "output": "[9, 9, 9, 9, 9, 9, 9, 234]"}, {"input": "s = \"ababababab\", queries = [[0,9],[1,8],[2,7],[3,6],[4,5]]", "output": "[30, 20, 12, 6, 2]"}, {"input": "s = \"aaaaabbbbbcccccdddddeeeee\", queries = [[0,4],[5,9],[10,14],[15,19],[20,24],[0,24]]", "output": "[15, 15, 15, 15, 15, 75]"}], "query": "You are an expert Python programmer. You will be given a question (problem specification) and will generate a correct Python program that matches the specification and passes all tests.\n\n### Question:\nYou are given a 0-indexed string s, and a 2D array of integers queries, where queries[i] = [li, ri] indicates a substring of s starting from the index li and ending at the index ri (both inclusive), i.e. s[li..ri].\nReturn an array ans where ans[i] is the number of same-end substrings of queries[i].\nA 0-indexed string t of length n is called same-end if it has the same character at both of its ends, i.e., t[0] == t[n - 1].\nA substring is a contiguous non-empty sequence of characters within a string.\n \nExample 1:\n\nInput: s = \"abcaab\", queries = [[0,0],[1,4],[2,5],[0,5]]\nOutput: [1,5,5,10]\nExplanation: Here is the same-end substrings of each query:\n1st query: s[0..0] is \"a\" which has 1 same-end substring: \"a\".\n2nd query: s[1..4] is \"bcaa\" which has 5 same-end substrings: \"bcaa\", \"bcaa\", \"bcaa\", \"bcaa\", \"bcaa\".\n3rd query: s[2..5] is \"caab\" which has 5 same-end substrings: \"caab\", \"caab\", \"caab\", \"caab\", \"caab\".\n4th query: s[0..5] is \"abcaab\" which has 10 same-end substrings: \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\", \"abcaab\".\n\nExample 2:\n\nInput: s = \"abcd\", queries = [[0,3]]\nOutput: [4]\nExplanation: The only query is s[0..3] which is \"abcd\". It has 4 same-end substrings: \"abcd\", \"abcd\", \"abcd\", \"abcd\".\n\n \nConstraints:\n\n2 <= s.length <= 3 * 104\ns consists only of lowercase English letters.\n1 <= queries.length <= 3 * 104\nqueries[i] = [li, ri]\n0 <= li <= ri < s.length\n\n\n\n### Format: You will use the following starter code to write the solution to the problem and enclose your code within delimiters.\n```python\nclass Solution:\n    def sameEndSubstringCount(self, s: str, queries: List[List[int]]) -> List[int]:\n        \n```\n\n### Answer: (use the provided format with backticks)\n", "response": "To solve the problem efficiently, we need to preprocess the string `s` to allow us to quickly answer the queries. One effective way to do this is by using prefix sums. Specifically, we can create a 2D list `prefix_count` where `prefix_count[i][c]` stores the number of occurrences of character `c` up to the `i`-th index in the string `s`.\n\nWith this prefix count array, for any query `[li, ri]`, we can determine the number of occurrences of each character in the substring `s[li:ri+1]`. The number of same-end substrings for each character can be computed using the combination formula for choosing 2 positions from the count of that character, plus the count itself for single-character substrings.\n\nHere's the implementation:\n\n```python\nfrom typing import List\n\nclass Solution:\n    def sameEndSubstringCount(self, s: str, queries: List[List[int]]) -> List[int]:\n        n = len(s)\n        # prefix_count[i][c] will store the count of character c up to index i\n        prefix_count = [[0] * 26 for _ in range(n + 1)]\n        \n        # Fill the prefix count array\n        for i in range(n):\n            for c in range(26):\n                prefix_count[i + 1][c] = prefix_count[i][c]\n            prefix_count[i + 1][ord(s[i]) - ord('a')] += 1\n        \n        ans = []\n        for li, ri in queries:\n            count_same_end = 0\n            for c in range(26):\n                count = prefix_count[ri + 1][c] - prefix_count[li][c]\n                if count > 0:\n                    # Number of same-end substrings for this character\n                    count_same_end += count * (count + 1) // 2\n            ans.append(count_same_end)\n        \n        return ans\n```\n\n### Explanation:\n1. **Prefix Count Array**:\n   - We initialize a 2D list `prefix_count` where `prefix_count[i][c]` keeps track of how many times character `c` appears from the start of the string up to index `i-1`.\n   - We iterate through the string `s` and update the prefix counts accordingly.\n\n2. **Query Processing**:\n   - For each query `[li, ri]`, we determine the number of occurrences of each character in the substring `s[li:ri+1]` using the difference between the prefix counts at `ri+1` and `li`.\n   - For each character that appears `count` times in the substring, the number of same-end substrings is given by the combination formula `count * (count + 1) / 2`.\n   - We sum these values for all characters to get the total number of same-end substrings for the query.\n\n3. **Result**:\n   - We return the results for all queries in the list `ans`.\n\nThis approach ensures that each query is processed in constant time after an initial preprocessing step that takes linear time relative to the length of the string `s`. This makes the solution efficient even for the upper constraint limits.", "estimated_date": 1701561600000}