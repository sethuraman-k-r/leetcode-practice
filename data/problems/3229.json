len(nums)\n        f = abs(target[0] - nums[0])\n        for i in range(1, n):\n            x = target[i] - nums[i]\n            y = target[i - 1] - nums[i - 1]\n            if x * y > 0:\n                d = abs(x) - abs(y)\n                if d > 0:\n                    f += d\n            else:\n                f += abs(x)\n        return f\n```", "estimated_date": 1721520000000}